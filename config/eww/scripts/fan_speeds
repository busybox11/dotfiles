#!/bin/bash

hostname=$(cat /etc/hostname)

# default fan paths
cpu_path="/sys/class/hwmon/hwmon3/fan1_input"
gpu_path="/sys/class/hwmon/hwmon3/fan2_input"

if [ "$hostname" = "workbox" ] || sensors | grep -q "dell_ddv-virtual-0"; then
  cpu_path="/sys/class/hwmon/hwmon1/fan1_input"
  gpu_path="/sys/class/hwmon/hwmon1/fan1_input"
elif [ "$hostname" = "realbox" ]; then
  cpu_path="/sys/class/hwmon/hwmon1/fan1_input"
  gpu_path="/sys/class/hwmon/hwmon1/fan1_input"
elif [ "$hostname" = "powerbox" ]; then
  cpu_path="/sys/devices/platform/asus-nb-wmi/hwmon/hwmon4/fan1_input"
  gpu_path="/sys/devices/platform/asus-nb-wmi/hwmon/hwmon4/fan2_input"
fi

cpu_speed=$(cat "$cpu_path" 2>/dev/null || echo 0)
gpu_speed=$(cat "$gpu_path" 2>/dev/null || echo 0)

if [ "$cpu_speed" -gt "$gpu_speed" ]; then
  max_speed=$cpu_speed
else
  max_speed=$gpu_speed
fi

formatted="CPU : $cpu_speed | GPU : $gpu_speed"
printf '{"cpu":%s,"gpu":%s,"max":%s,"formatted":"%s"}\n' "$cpu_speed" "$gpu_speed" "$max_speed" "$formatted"
