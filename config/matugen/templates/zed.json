// NOTE: This file uses JSONC-style inline comments for readability.
{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Matugen Theme",
  "author": "svturnring",
  "themes": [
    {
      "name": "Matugen Dark",
      "appearance": "dark",
      // "style" groups tokens the Zed theme engine consumes. Sections
      // below divide keys by their semantic purpose (accents, surfaces,
      // controls, editor, terminal, VC statuses, syntax, etc.).
      "style": {
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Accents
        // Main accent palette used for emphasis and CTAs
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "accents": [
          "{{colors.primary.dark.hex}}",
          "{{colors.secondary.dark.hex}}",
          "{{colors.tertiary.dark.hex}}"
        ],

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Backgrounds & Surfaces
        // Base background and surface layers
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "background.appearance": "opaque",
        "elevated_surface.background": "{{colors.surface_container_high.dark.hex}}",
        "surface.background": "{{colors.surface.dark.hex}}",
        "background": "{{colors.background.dark.hex | saturate:2,hsl | lighten:3,hsl}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Text & Iconography
        // Text colors for normal, muted, disabled, and accent states
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "text": "{{colors.on_surface.dark.hex}}",
        "text.muted": "{{colors.on_surface_variant.dark.hex}}",
        "text.placeholder": "{{colors.on_surface_variant.dark.hex}}99",
        "text.disabled": "{{colors.on_surface.dark.hex}}60",
        "text.accent": "{{colors.primary.dark.hex}}",
        "icon": "{{colors.on_surface.dark.hex}}",
        "icon.muted": "{{colors.on_surface_variant.dark.hex}}",
        "icon.disabled": "{{colors.on_surface.dark.hex}}60",
        "icon.placeholder": "{{colors.on_surface_variant.dark.hex}}80",
        "icon.accent": "{{colors.primary.dark.hex}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Syntax Highlighting
        // Mapping of token types to colors and text styles
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "syntax": {
          // Function and method names (definitions and calls)
          "function": {
            "color": "{{colors.primary.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Language keywords (if, for, return, class, etc.)
          "keyword": {
            "color": "{{colors.secondary.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Variable names and identifiers
          "variable": {
            "color": "{{colors.on_surface.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // String literals ("text", 'text', `text`)
          "string": {
            "color": "{{colors.tertiary.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Numeric literals (integers, floats, hex, binary)
          "number": {
            "color": "{{colors.tertiary_fixed.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Primitive values: true, false, null, undefined
          "boolean": {
            "color": "{{colors.tertiary.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Type annotations and declarations (int, string, MyClass, etc.)
          "type": {
            "color": "{{colors.primary_fixed.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Object properties and struct fields
          "property": {
            "color": "{{colors.on_surface.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Constants and immutable values (SCREAMING_SNAKE_CASE, const)
          "constant": {
            "color": "{{colors.tertiary.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Single-line and block comments
          "comment": {
            "color": "{{colors.on_surface_variant.dark.hex}}",
            "font_style": "italic",
            "font_weight": null
          },
          // Documentation comments (JSDoc, docstrings, etc.)
          "comment.doc": {
            "color": "{{colors.on_surface_variant.dark.hex}}",
            "font_style": "italic",
            "font_weight": null
          },
          // Operators (+, -, *, /, ==, &&, etc.)
          "operator": {
            "color": "{{colors.on_surface_variant.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // General punctuation (commas, semicolons, etc.)
          "punctuation": {
            "color": "{{colors.on_surface_variant.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Brackets and braces: (), {}, []
          "punctuation.bracket": {
            "color": "{{colors.secondary_fixed.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Delimiters: commas, semicolons, colons
          "punctuation.delimiter": {
            "color": "{{colors.on_surface_variant.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Special punctuation (template string delimiters, etc.)
          "punctuation.special": {
            "color": "{{colors.secondary.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Escape sequences in strings (\n, \t, \", \\, etc.)
          "string.escape": {
            "color": "{{colors.tertiary_fixed_dim.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Regular expression patterns
          "string.regex": {
            "color": "{{colors.tertiary_fixed.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Special string types (raw strings, format strings, etc.)
          "string.special": {
            "color": "{{colors.on_tertiary_container.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Class constructors and initializers
          "constructor": {
            "color": "{{colors.secondary.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // HTML/XML tags (<div>, </span>, etc.)
          "tag": {
            "color": "{{colors.secondary.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Italic text in Markdown/docs (emphasis, *text*)
          "emphasis": {
            "color": "{{colors.primary.dark.hex}}",
            "font_style": "italic",
            "font_weight": null
          },
          // Bold text in Markdown/docs (strong emphasis, **text**)
          "emphasis.strong": {
            "color": "{{colors.primary.dark.hex}}",
            "font_style": null,
            "font_weight": 700
          },
          // Markdown list markers (-, *, 1., etc.)
          "punctuation.list_marker": {
            "color": "{{colors.on_surface_variant.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Plain text in structured documents (Markdown content, etc.)
          "text.literal": {
            "color": "{{colors.tertiary.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Special variables (this, self, super, etc.)
          "variable.special": {
            "color": "{{colors.primary.dark.hex}}",
            "font_style": null,
            "font_weight": null
          },
          // Symbols in Lisp/Ruby (:symbol, 'symbol)
          "string.special.symbol": {
            "color": "{{colors.tertiary.dark.hex}}",
            "font_style": null,
            "font_weight": null
          }
        },

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Editor UI
        // Gutter, guides, active/highlighted lines, and document highlights
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "editor.foreground": "{{colors.on_surface.dark.hex}}",
        "editor.background": "{{colors.background.dark.hex | saturate:2,hsl | lighten:3,hsl}}",
        "editor.gutter.background": "{{colors.background.dark.hex | saturate:2,hsl | lighten:3,hsl}}",
        "editor.subheader.background": "{{colors.surface_container.dark.hex}}",
        "editor.indent_guide": "{{colors.outline_variant.dark.hex}}60",
        "editor.indent_guide_active": "{{colors.outline_variant.dark.hex}}70",
        "editor.active_line.background": "{{colors.surface_container_high.dark.hex | saturate:2,hsl}}60",
        "editor.highlighted_line.background": "{{colors.surface_container_high.dark.hex}}60",
        "editor.line_number": "{{colors.on_surface_variant.dark.hex}}",
        "editor.active_line_number": "{{colors.primary.dark.hex}}",
        "editor.invisible": "{{colors.outline_variant.dark.hex}}80",
        "editor.wrap_guide": "{{colors.outline_variant.dark.hex}}40",
        "editor.active_wrap_guide": "{{colors.outline_variant.dark.hex}}80",
        "editor.document_highlight.read_background": "{{colors.primary_container.dark.hex}}60",
        "editor.document_highlight.write_background": "{{colors.secondary_container.dark.hex}}80",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Element States
        // Normal / hover / active / selected / disabled variants
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "element.background": "{{colors.surface_container.dark.hex}}",
        "element.hover": "{{colors.background.dark.hex | saturate:2,hsl | lighten:3,hsl}}",
        "element.active": "{{colors.surface_container_highest.dark.hex}}",
        "element.selected": "{{colors.background.dark.hex | saturate:2,hsl | lighten:6,hsl}}",
        "element.disabled": "{{colors.surface_variant.dark.hex}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Borders & Focus Visuals
        // Border states for focused, selected, and disabled elements
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "border": "{{colors.outline_variant.dark.hex}}70",
        "border.variant": "{{colors.outline_variant.dark.hex}}70",
        "border.focused": "{{colors.primary.dark.hex}}",
        "border.selected": "{{colors.primary.dark.hex}}",
        "border.transparent": "{{colors.outline_variant.dark.hex}}40",
        "border.disabled": "{{colors.outline_variant.dark.hex}}60",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Status Indicators: Error
        // Colors for error states and notifications
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "error": "{{colors.error.dark.hex}}",
        "error.background": "{{colors.error_container.dark.hex}}",
        "error.border": "{{colors.on_error_container.dark.hex}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Status Indicators: Warning
        // Colors for warning states and notifications
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "warning": "{{colors.tertiary_fixed_dim.dark.hex}}",
        "warning.background": "{{colors.tertiary_container.dark.hex}}80",
        "warning.border": "{{colors.on_tertiary_container.dark.hex}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Status Indicators: Success
        // Colors for success states and notifications
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "success": "{{colors.tertiary.dark.hex}}",
        "success.background": "{{colors.tertiary_container.dark.hex}}80",
        "success.border": "{{colors.on_tertiary_container.dark.hex}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Status Indicators: Hint
        // Colors for hint states and inline suggestions
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "hint": "{{colors.primary.dark.hex}}",
        "hint.background": "{{colors.primary_container.dark.hex}}80",
        "hint.border": "{{colors.on_primary_container.dark.hex}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Status Indicators: Info
        // Colors for informational states and notifications
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "info": "{{colors.primary.dark.hex}}",
        "info.background": "{{colors.primary_container.dark.hex}}80",
        "info.border": "{{colors.on_primary_container.dark.hex}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Diff Highlights
        // Colors used by diff views: inline hunk highlights, background overlays
        // and conflict markers. Background values commonly include an alpha
        // suffix (e.g. `...hex}}80`) to produce semi-transparent overlays.
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "conflict": "{{colors.error.dark.hex}}",
        "conflict.background": "{{colors.error_container.dark.hex}}80",
        "conflict.border": "{{colors.on_error_container.dark.hex}}",
        "deleted": "{{colors.error.dark.hex}}",
        "deleted.background": "{{colors.error_container.dark.hex}}80",
        "deleted.border": "{{colors.on_error_container.dark.hex}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Version Control: Created/Added
        // Colors for newly created or added files/lines in VC systems
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "created": "{{colors.tertiary.dark.hex}}",
        "created.background": "{{colors.tertiary_container.dark.hex}}80",
        "created.border": "{{colors.on_tertiary_container.dark.hex}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Version Control: Modified
        // Colors for modified files/lines in VC systems
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "modified": "{{colors.primary.dark.hex}}",
        "modified.background": "{{colors.secondary_container.dark.hex}}80",
        "modified.border": "{{colors.on_secondary_container.dark.hex}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
