        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Links
        // Hover/focus state for inline links, reference previews and clickable items.
        // Use a high-contrast accent color (primary) so links remain visible on
        // varying surface layers and editor backgrounds.
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "link_text.hover": "{{colors.primary.light.hex}}",

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Collaborative Player Cursors & Selections
        // Colors for multi-user cursors and selections in collaborative editing
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "players": [
          {
            "cursor": "{{colors.primary.light.hex}}",
            "background": "{{colors.primary_container.light.hex}}80",
            "selection": "{{colors.primary_container.light.hex}}60"
          },
          {
            "cursor": "{{colors.secondary.light.hex}}",
            "background": "{{colors.secondary_container.light.hex}}80",
            "selection": "{{colors.secondary_container.light.hex}}60"
          }
        ],

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Predictive/AI Markers
        // Colors for AI-generated or predictive code suggestions
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        "predictive": "{{colors.on_surface_variant.light.hex}}80",
        "predictive.border": "{{colors.outline_variant.light.hex}}",
        "predictive.background": "{{colors.surface_container_highest.light.hex}}80"
      }
    }
  ]
}
