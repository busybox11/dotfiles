#!/usr/bin/env bash
set -euo pipefail

secret_file="secrets/secrets.nix"

if git diff --cached --name-only --diff-filter=AM | grep -qxF "$secret_file"; then
  if ! git show ":${secret_file}" | od -An -tx1 | head -1 | grep -q '00 47 49 54 43 52 59 50 54 00'; then
    echo "error: ${secret_file} is staged but not git-crypt encrypted" >&2
    echo "hint: nix-shell -p git-crypt --run 'git add ${secret_file}'" >&2
    exit 1
  fi
fi
